{
  "name": "gaokao-app",
  "version": "0.0.0",
  "private": true,
  "description": "高考志愿填报系统 - Taro移动端",
  "templateInfo": {
    "name": "react-native",
    "typescript": true,
    "css": "Sass",
    "framework": "React"
  },
  "scripts": {
    "build:h5": "taro build --type h5",
    "dev:h5": "npm run build:h5 -- --watch",
    "build:weapp": "taro build --type weapp",
    "dev:weapp": "npm run build:weapp -- --watch",
    "build:rn": "taro build --type rn",
    "dev:rn": "npm run build:rn -- --watch",
    "build:rn:dev": "taro build --type rn --watch --qr",
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "upgradePeerdeps": "npx install-peerdeps @tarojs/taro-rn@4.1.11 -o -Y && npx install-peerdeps @tarojs/components-rn@4.1.11 -o -Y && npx install-peerdeps @tarojs/router-rn@4.1.11 -o -Y && npx pod-install"
  },
  "browserslist": [
    "last 3 versions",
    "Android >= 4.1",
    "ios >= 8"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@babel/runtime": "^7.24.0",
    "@tarojs/components": "4.1.11",
    "@tarojs/components-rn": "4.1.11",
    "@tarojs/helper": "4.1.11",
    "@tarojs/plugin-framework-react": "4.1.11",
    "@tarojs/plugin-platform-h5": "4.1.11",
    "@tarojs/plugin-platform-weapp": "4.1.11",
    "@tarojs/react": "4.1.11",
    "@tarojs/router-rn": "4.1.11",
    "@tarojs/runtime": "4.1.11",
    "@tarojs/shared": "4.1.11",
    "@tarojs/taro": "4.1.11",
    "@tarojs/taro-rn": "4.1.11",
    "antd-mobile": "^5.38.0",
    "axios": "^1.13.6",
    "dayjs": "^1.11.20",
    "echarts": "^5.6.0",
    "echarts-for-react": "^3.0.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-native": "^0.76.6",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/plugin-transform-class-properties": "7.25.9",
    "@babel/preset-react": "^7.24.0",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.5.11",
    "@tarojs/cli": "4.1.11",
    "@tarojs/rn-runner": "4.1.11",
    "@tarojs/taro-loader": "4.1.11",
    "@tarojs/webpack5-runner": "4.1.11",
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.0",
    "@types/webpack-env": "^1.18.4",
    "babel-preset-taro": "4.1.11",
    "eslint": "^8.57.0",
    "eslint-config-taro": "4.1.11",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "pod-install": "^0.2.0",
    "postcss": "^8.4.35",
    "react-refresh": "^0.14.0",
    "sass": "^1.71.0",
    "sass-loader": "^14.1.0",
    "stylelint": "^16.2.0",
    "tsconfig-paths-webpack-plugin": "^4.1.0",
    "typescript": "^5.4.0",
    "webpack": "^5.90.0"
  }
}
